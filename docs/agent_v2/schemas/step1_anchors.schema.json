{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "profit.agent.step1.anchors.schema.json",
  "title": "Agent Step 1 - Anchors IR (v2)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "context",
    "data_needed_fluid",
    "needs_data",
    "can_answer_now",
    "stop_reason",
    "anchors",
    "insight_ops",
    "missing_sources"
  ],
  "properties": {
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["user_query", "approach"],
      "properties": {
        "user_query": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "approach": { "type": "string", "minLength": 1, "maxLength": 2000 }
      }
    },
    "data_needed_fluid": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 240 }
    },
    "needs_data": { "type": "boolean" },
    "can_answer_now": { "type": "boolean" },
    "stop_reason": {
      "type": "string",
      "enum": ["answered", "need_more_data", "insufficient_datasets", "need_clarification"]
    },
    "clarifying_questions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 240 },
      "description": "Optional: only when stop_reason=need_clarification."
    },
    "final_answer": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20000,
      "description": "Optional: present when can_answer_now=true or stop_reason=answered."
    },
    "anchors": {
      "type": "array",
      "items": { "$ref": "#/$defs/Anchor" }
    },
    "insight_ops": { "$ref": "#/$defs/InsightOps" },
    "insights_writeback": {
      "type": "array",
      "items": { "$ref": "#/$defs/SnippetWriteback" },
      "description": "Optional: snippets the agent wants stored."
    },
    "missing_sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/MissingSource" }
    }
  },
  "$defs": {
    "Mic": {
      "type": "string",
      "pattern": "^[A-Z0-9]{4}$",
      "description": "ISO 10383 MIC (4 chars)."
    },
    "Ticker": {
      "type": "string",
      "minLength": 1,
      "maxLength": 24
    },
    "Priority": {
      "type": "string",
      "enum": ["must", "should", "nice_to_have"]
    },
    "DateRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_utc", "end_utc"],
      "properties": {
        "start_utc": { "type": "string", "format": "date" },
        "end_utc": { "type": "string", "format": "date" }
      },
      "description": "Date-only UTC range; inclusive start and inclusive end."
    },
    "EntityMic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ticker", "exchange_mic"],
      "properties": {
        "ticker": { "$ref": "#/$defs/Ticker" },
        "exchange_mic": { "$ref": "#/$defs/Mic" }
      }
    },
    "AnchorBase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "priority", "purpose", "time_range"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["market_ohlcv", "edgar_xbrl", "real_estate_intent"]
        },
        "priority": { "$ref": "#/$defs/Priority" },
        "purpose": { "type": "string", "minLength": 1, "maxLength": 240 },
        "time_range": { "$ref": "#/$defs/DateRange" }
      }
    },

    "MarketField": {
      "type": "string",
      "enum": ["open", "high", "low", "close", "volume", "adj_close"]
    },
    "MarketTransform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "enum": ["x_day_avg", "x_day_min", "x_day_max", "resample"] },
        "field": { "$ref": "#/$defs/MarketField" },
        "window_days": { "type": "integer", "minimum": 2, "maximum": 400 },
        "resample_to": { "type": "string", "enum": ["1w", "1mo"] },
        "method": { "type": "string", "enum": ["mean", "min", "max", "sum", "last"] }
      },
      "allOf": [
        {
          "if": { "properties": { "name": { "const": "x_day_avg" } }, "required": ["name"] },
          "then": { "required": ["field", "window_days"] }
        },
        {
          "if": { "properties": { "name": { "const": "x_day_min" } }, "required": ["name"] },
          "then": { "required": ["field", "window_days"] }
        },
        {
          "if": { "properties": { "name": { "const": "x_day_max" } }, "required": ["name"] },
          "then": { "required": ["field", "window_days"] }
        },
        {
          "if": { "properties": { "name": { "const": "resample" } }, "required": ["name"] },
          "then": { "required": ["resample_to", "method"] }
        }
      ]
    },
    "MarketAnchor": {
      "allOf": [
        { "$ref": "#/$defs/AnchorBase" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["entity", "bar_size", "fields"],
          "properties": {
            "type": { "const": "market_ohlcv" },
            "entity": { "$ref": "#/$defs/EntityMic" },
            "bar_size": { "type": "string", "enum": ["1d"] },
            "fields": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/MarketField" },
              "uniqueItems": true
            },
            "adjustments": {
              "type": "object",
              "additionalProperties": false,
              "required": ["splits", "dividends"],
              "properties": {
                "splits": { "type": "boolean" },
                "dividends": { "type": "boolean" }
              }
            },
            "transforms": {
              "type": "array",
              "items": { "$ref": "#/$defs/MarketTransform" }
            }
          }
        }
      ]
    },

    "EdgarPeriodType": { "type": "string", "enum": ["instant", "duration"] },
    "EdgarGrain": { "type": "string", "enum": ["quarterly", "annual", "ttm"] },
    "QName": { "type": "string", "minLength": 3, "maxLength": 200 },
    "EdgarMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "concept_qnames_allow"],
      "properties": {
        "kind": { "type": "string", "minLength": 1, "maxLength": 64 },
        "concept_qnames_allow": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/QName" },
          "uniqueItems": true
        }
      }
    },
    "EdgarDimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["axis_qnames_allow", "member_qnames_allow"],
      "properties": {
        "axis_qnames_allow": {
          "type": "array",
          "items": { "$ref": "#/$defs/QName" },
          "uniqueItems": true
        },
        "member_qnames_allow": {
          "type": "array",
          "items": { "$ref": "#/$defs/QName" },
          "uniqueItems": true
        }
      }
    },
    "EdgarUnits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["measures_allow"],
      "properties": {
        "measures_allow": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 64 },
          "uniqueItems": true
        }
      }
    },
    "EdgarAnchor": {
      "allOf": [
        { "$ref": "#/$defs/AnchorBase" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["entity", "period_type", "grain", "metric"],
          "properties": {
            "type": { "const": "edgar_xbrl" },
            "entity": { "$ref": "#/$defs/EntityMic" },
            "allow_ambiguous_cik": { "type": "boolean", "default": false },
            "period_type": { "$ref": "#/$defs/EdgarPeriodType" },
            "grain": { "$ref": "#/$defs/EdgarGrain" },
            "metric": { "$ref": "#/$defs/EdgarMetric" },
            "dimensions": { "$ref": "#/$defs/EdgarDimensions" },
            "units": { "$ref": "#/$defs/EdgarUnits" }
          }
        }
      ]
    },

    "RealEstateGrain": { "type": "string", "enum": ["monthly", "quarterly", "annual"] },
    "RealEstateAnchor": {
      "allOf": [
        { "$ref": "#/$defs/AnchorBase" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["entity_scope", "grain", "measures"],
          "properties": {
            "type": { "const": "real_estate_intent" },
            "entity_scope": {
              "type": "object",
              "additionalProperties": false,
              "required": ["geo_id"],
              "properties": {
                "geo_id": { "type": "string", "minLength": 1, "maxLength": 128 }
              }
            },
            "grain": { "$ref": "#/$defs/RealEstateGrain" },
            "measures": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1, "maxLength": 64 },
              "uniqueItems": true
            },
            "filters": {
              "type": "object",
              "additionalProperties": true,
              "description": "Free-form filters interpreted by the Step 2 SQL compiler."
            }
          }
        }
      ]
    },

    "Anchor": {
      "oneOf": [
        { "$ref": "#/$defs/MarketAnchor" },
        { "$ref": "#/$defs/EdgarAnchor" },
        { "$ref": "#/$defs/RealEstateAnchor" }
      ]
    },

    "InsightQuery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tags", "freshness_horizon_days", "intent"],
      "properties": {
        "tags": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1, "maxLength": 64 },
          "uniqueItems": true
        },
        "freshness_horizon_days": { "type": "integer", "minimum": 1, "maximum": 3650 },
        "intent": { "type": "string", "minLength": 1, "maxLength": 240 }
      }
    },
    "InsightStoreCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proposed_tags", "intent"],
      "properties": {
        "proposed_tags": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1, "maxLength": 64 },
          "uniqueItems": true
        },
        "intent": { "type": "string", "minLength": 1, "maxLength": 240 }
      }
    },
    "InsightOps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["search", "store_candidates"],
      "properties": {
        "search": { "type": "array", "items": { "$ref": "#/$defs/InsightQuery" } },
        "store_candidates": { "type": "array", "items": { "$ref": "#/$defs/InsightStoreCandidate" } }
      }
    },

    "MissingSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "why", "priority"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 64 },
        "why": { "type": "string", "minLength": 1, "maxLength": 240 },
        "priority": { "type": "string", "enum": ["future"] }
      }
    },

    "SnippetWriteback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "body", "tags"],
      "properties": {
        "title": { "type": "string", "minLength": 1, "maxLength": 120 },
        "body": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "maxLength": 240 } },
        "tags": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "maxLength": 64 }, "uniqueItems": true },
        "related_instruments": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 64 }, "uniqueItems": true },
        "related_regions": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 128 }, "uniqueItems": true },
        "expires_at_utc": { "type": "string", "format": "date-time" }
      }
    }
  }
}
