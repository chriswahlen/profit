{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "profit.agent.step2.retrieval_plan.schema.json",
  "title": "Agent Step 2 - Retrieval Plan (v2)",
  "type": "object",
  "additionalProperties": false,
  "required": ["entity_resolution_report", "batches"],
  "properties": {
    "entity_resolution_report": {
      "type": "array",
      "items": { "$ref": "#/$defs/EntityResolution" }
    },
    "batches": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Batch" }
    }
  },
  "$defs": {
    "Mic": { "type": "string", "pattern": "^[A-Z0-9]{4}$" },
    "Ticker": { "type": "string", "minLength": 1, "maxLength": 24 },
    "EntityMic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ticker", "exchange_mic"],
      "properties": {
        "ticker": { "$ref": "#/$defs/Ticker" },
        "exchange_mic": { "$ref": "#/$defs/Mic" }
      }
    },
    "EntityResolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["anchor_id", "entity", "status"],
      "properties": {
        "anchor_id": { "type": "string", "minLength": 1 },
        "entity": { "$ref": "#/$defs/EntityMic" },
        "status": { "type": "string", "enum": ["ok", "not_found", "ambiguous", "error"] },
        "resolved": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cik"],
          "properties": { "cik": { "type": "string", "minLength": 1, "maxLength": 16 } }
        },
        "note": { "type": "string", "maxLength": 240 }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "ok" } }, "required": ["status"] },
          "then": { "required": ["resolved"] }
        }
      ]
    },

    "Batch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["batch_id", "purpose", "requests"],
      "properties": {
        "batch_id": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1, "maxLength": 240 },
        "depends_on_batches": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "requests": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Request" }
        }
      }
    },

    "RequestBase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_id", "type"],
      "properties": {
        "request_id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "enum": ["market_ohlcv", "sql"] }
      }
    },

    "MarketField": { "type": "string", "enum": ["open", "high", "low", "close", "volume", "adj_close"] },
    "MarketOhlcvRequest": {
      "allOf": [
        { "$ref": "#/$defs/RequestBase" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "params"],
          "properties": {
            "type": { "const": "market_ohlcv" },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "required": ["ticker", "exchange_mic", "start_utc", "end_utc", "bar_size", "fields"],
              "properties": {
                "ticker": { "$ref": "#/$defs/Ticker" },
                "exchange_mic": { "$ref": "#/$defs/Mic" },
                "start_utc": { "type": "string", "format": "date" },
                "end_utc": { "type": "string", "format": "date" },
                "bar_size": { "type": "string", "enum": ["1d"] },
                "fields": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "$ref": "#/$defs/MarketField" },
                  "uniqueItems": true
                },
                "adjust_splits": { "type": "boolean" },
                "adjust_dividends": { "type": "boolean" },
                "post_aggregations": { "type": "array", "items": { "type": "object", "additionalProperties": true } }
              }
            },
            "timeout_ms": { "type": "integer", "minimum": 1000, "maximum": 300000 }
          }
        }
      ]
    },

    "SqlRequest": {
      "allOf": [
        { "$ref": "#/$defs/RequestBase" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "dataset", "params"],
          "properties": {
            "type": { "const": "sql" },
            "dataset": { "type": "string", "enum": ["edgar", "real_estate"] },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "required": ["dialect", "read_only", "sql", "timeout_ms", "max_rows"],
              "properties": {
                "dialect": { "type": "string", "enum": ["sqlite", "postgres"] },
                "read_only": { "type": "boolean", "const": true },
                "sql": { "type": "string", "minLength": 1 },
                "timeout_ms": { "type": "integer", "minimum": 1000, "maximum": 300000 },
                "max_rows": { "type": "integer", "minimum": 1, "maximum": 200000 }
              }
            }
          }
        }
      ]
    },

    "Request": {
      "oneOf": [
        { "$ref": "#/$defs/MarketOhlcvRequest" },
        { "$ref": "#/$defs/SqlRequest" }
      ]
    }
  }
}

